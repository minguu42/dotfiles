{
  "respectGitignore": false,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true",
    "CLAUDE_CODE_HIDE_ACCOUNT_INFO": "true",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "true",
    "DISABLE_BUG_COMMAND": "true",
    "DISABLE_ERROR_REPORTING": "true",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "true",
    "DISABLE_TELEMETRY": "true"
  },
  "permissions": {
    "allow": [
      "Bash(aws batch describe-job-queues:*)",
      "Bash(aws batch list-jobs:*)",
      "Bash(aws ecr describe-images:*)",
      "Bash(aws ec2 describe-instances:*)",
      "Bash(benchstat:*)",
      "Bash(cat:*)",
      "Bash(do:*)",
      "Bash(docker container logs:*)",
      "Bash(docker image:*)",
      "Bash(done)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(find:*)",
      "Bash(for:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh release list)",
      "Bash(gh release view)",
      "Bash(gh run view:*)",
      "Bash(gh search:*)",
      "Bash(ghq list:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(go build:*)",
      "Bash(go clean:*)",
      "Bash(go doc:*)",
      "Bash(go env:*)",
      "Bash(go fix:*)",
      "Bash(go fmt:*)",
      "Bash(go generate:*)",
      "Bash(go get:*)",
      "Bash(go list:*)",
      "Bash(go mod graph:*)",
      "Bash(go mod tidy:*)",
      "Bash(go run:*)",
      "Bash(go test:*)",
      "Bash(go tool:*)",
      "Bash(go version:*)",
      "Bash(go vet:*)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(nc:*)",
      "Bash(rm:*)",
      "Bash(tee:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Read(//tmp/**)",
      "WebFetch(domain:clickhouse.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:google.github.io)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:qiita.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:tip.golang.org)",
      "WebSearch"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(git -C:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git rm:*)",
      "Bash(rm -rf:*)",
      "Bash(scp:*)",
      "Bash(ssh:*)",
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.envrc)",
      "Edit(.env)",
      "Edit(.envrc)"
    ],
    "defaultMode": "auto",
    "disableBypassPermissionsMode": "disable"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message' | terminal-notifier -title 'Claude Code' -sound 'Boop'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -message 'Claude has completed the task.' -sound 'Boop'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-code-statusline",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "forceLoginMethod": "claudeai",
  "language": "japanese",
  "spinnerTipsEnabled": false,
  "effortLevel": "xhigh",
  "plansDirectory": "./.claude/plans",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "showTurnDuration": true,
  "voiceEnabled": true
}

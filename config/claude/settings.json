{
  "respectGitignore": false,
  "env": {
    "AWS_MCP_PROXY_PROFILES": "sot-sandbox-readonly",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true",
    "CLAUDE_CODE_HIDE_ACCOUNT_INFO": "true",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "true",
    "DISABLE_BUG_COMMAND": "true",
    "DISABLE_ERROR_REPORTING": "true",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "true",
    "DISABLE_TELEMETRY": "true"
  },
  "deniedMcpServers": [
    { "serverUrl": "https://gmailmcp.googleapis.com/*" },
    { "serverUrl": "https://calendarmcp.googleapis.com/*" },
    { "serverUrl": "https://drivemcp.googleapis.com/*" },
    { "serverUrl": "https://mcp.canva.com/*" }
  ],
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(aws:*)",
      "Bash(curl:*)",
      "Bash(git -C:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git rm:*)",
      "Bash(rm -rf:*)",
      "Bash(scp:*)",
      "Bash(ssh:*)",
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.envrc)",
      "Edit(.env)",
      "Edit(.envrc)"
    ],
    "defaultMode": "auto",
    "disableBypassPermissionsMode": "disable"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message' | terminal-notifier -title 'Claude Code' -sound 'Boop'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -message 'Claude has completed the task.' -sound 'Boop'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-code-statusline",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "aws-core@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "forceLoginMethod": "claudeai",
  "language": "japanese",
  "spinnerTipsEnabled": false,
  "effortLevel": "xhigh",
  "plansDirectory": "./.claude/plans",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "showTurnDuration": true,
  "voiceEnabled": true
}

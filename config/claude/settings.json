{
  "respectGitignore": false,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_HIDE_ACCOUNT_INFO": "true",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "true",
    "DISABLE_BUG_COMMAND": "true",
    "DISABLE_ERROR_REPORTING": "true",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "true",
    "DISABLE_TELEMETRY": "true"
  },
  "permissions": {
    "allow": [
      "Bash(benchstat:*)",
      "Bash(cat:*)",
      "Bash(do:*)",
      "Bash(docker container:*)",
      "Bash(docker image:*)",
      "Bash(done)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(find:*)",
      "Bash(for:*)",
      "Bash(gh pr:*)",
      "Bash(gh run view:*)",
      "Bash(gh search:*)",
      "Bash(ghq list:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(go build:*)",
      "Bash(go clean:*)",
      "Bash(go doc:*)",
      "Bash(go fmt:*)",
      "Bash(go generate:*)",
      "Bash(go get:*)",
      "Bash(go list:*)",
      "Bash(go mod tidy:*)",
      "Bash(go run:*)",
      "Bash(go test:*)",
      "Bash(go tool:*)",
      "Bash(go vet:*)",
      "Bash(gofmt:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(tee:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:google.github.io)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:tip.golang.org)",
      "WebFetch(domain:qiita.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.envrc)",
      "Write(.env)",
      "Write(.envrc)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".go\"))' | xargs -r go tool goimports -w"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".go\"))' | xargs -r dirname | xargs -r go fix"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message' | terminal-notifier -title 'Claude Code' -sound 'Boop'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-code-statusline",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "forceLoginMethod": "claudeai",
  "language": "japanese",
  "spinnerTipsEnabled": false,
  "plansDirectory": "./.claude/plans",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "showTurnDuration": true
}
